# Copy to .env.local and fill in. Never commit real keys.
#
# Optional LLM phrasing for /api/agent (dev / non-static hosts only).
# GitHub Pages is a static export - the browser agent still works without any key.
#
# Good free / high-limit options for a white-label chat backend:
#   1) Google AI Studio (Gemini Flash) - already wired below
#      https://aistudio.google.com/apikey
#   2) GitHub Models - free with a GitHub PAT (models:read)
#      https://github.com/marketplace/models
#      Endpoint: https://models.github.ai/inference  (OpenAI-compatible)
#   3) Groq - very fast free tier (no card)
#      https://console.groq.com/keys
#   4) OpenRouter :free models - broad catalog, lower daily caps
#      https://openrouter.ai/keys
#
# For white-label on policywell.ai (static Pages), keep keys on a tiny
# backend (Cloudflare Worker / Vercel / Fly) - never ship them to the browser.

GOOGLE_GENERATIVE_AI_API_KEY=

# Optional alternatives if you extend llm.ts:
# GITHUB_MODELS_TOKEN=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
